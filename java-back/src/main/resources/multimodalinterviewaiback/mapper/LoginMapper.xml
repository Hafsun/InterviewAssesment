<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="multimodalinterviewaiback.mapper.LoginMapper">

    <!-- 根据用户名查询密保问题 -->
    <select id="getPassProtectByUsername" parameterType="java.lang.String" resultType="java.lang.String">
        SELECT passProtect FROM user WHERE username = #{username}
    </select>
    <!-- 根据用户名查询密保答案 -->
    <select id="getPassProtectAnswerByUsername" parameterType="java.lang.String" resultType="java.lang.String">
        SELECT passProtectAnswer FROM user WHERE username = #{username}
    </select>
    <!-- 根据用户名更新密码 -->
    <update id="updatePasswordByUsername">
        UPDATE user SET password = #{newPassword} WHERE username = #{username}
    </update>
</mapper>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="multimodalinterviewaiback.mapper.TopPerformanceMapper">
    <!-- 新增优势表现 -->
    <insert id="insert" parameterType="multimodalinterviewaiback.pojo.entity.TopPerformanceEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO top_performance (
            report_id,
            problem_summary,
            round_number,
            strengths
        ) VALUES (
                #{report_id},
                #{problem_summary},
                #{round_number},
                #{strengths}
                 )
    </insert>

    <!-- 根据报告ID查询优势表现列表 -->
    <select id="selectByReportId" parameterType="java.lang.Integer" resultType="multimodalinterviewaiback.pojo.entity.TopPerformanceEntity">
        SELECT
            id,
            report_id AS reportId,
            problem_summary AS problemSummary
        FROM top_performance
        WHERE report_id = #{reportId}
    </select>
    <select id="getTopPerformanceDTOList"
            resultType="multimodalinterviewaiback.pojo.dto.TopPerformanceDTO">
        select problem_summary, round_number, strengths
        from top_performance
        where report_id = #{reportId}
    </select>

    <delete id="deleteByReportId" parameterType="java.lang.Integer">
        DELETE FROM top_performance WHERE report_id = #{reportId}
    </delete>
</mapper>
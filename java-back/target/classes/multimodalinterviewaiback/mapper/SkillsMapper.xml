<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="multimodalinterviewaiback.mapper.SkillsMapper">

    <insert id="insert" parameterType="multimodalinterviewaiback.pojo.entity.Skills">
        INSERT INTO skills
            (personal_id, professional_skills, languages, other_skills)
        VALUES
            (#{personalId}, #{professionalSkills}, #{languages}, #{otherSkills})
    </insert>

    <delete id="deleteByPersonalId" parameterType="java.lang.Long">
        DELETE FROM skills WHERE personal_id = #{personalId}
    </delete>

    <select id="selectByPersonalId" parameterType="java.lang.Long" resultType="multimodalinterviewaiback.pojo.entity.Skills">
        SELECT * FROM skills WHERE personal_id = #{personalId}
    </select>
</mapper>
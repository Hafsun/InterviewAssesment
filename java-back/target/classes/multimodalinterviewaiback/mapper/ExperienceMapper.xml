<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="multimodalinterviewaiback.mapper.ExperienceMapper">

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO experience
        (personal_id, company, period, position, department, responsibilities, achievements)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.personalId}, #{item.company}, #{item.period}, #{item.position},
            #{item.department}, #{item.responsibilities}, #{item.achievements})
        </foreach>
    </insert>

    <delete id="deleteByPersonalId" parameterType="java.lang.Long">
        DELETE FROM experience WHERE personal_id = #{personalId}
    </delete>

    <select id="selectByPersonalId" parameterType="java.lang.Long" resultType="multimodalinterviewaiback.pojo.entity.Experience">
        SELECT * FROM experience WHERE personal_id = #{personalId}
    </select>
</mapper>
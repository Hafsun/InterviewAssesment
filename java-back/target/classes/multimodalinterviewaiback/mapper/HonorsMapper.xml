<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="multimodalinterviewaiback.mapper.HonorsMapper">

    <insert id="insert" parameterType="multimodalinterviewaiback.pojo.entity.Honors">
        INSERT INTO honors
            (personal_id, certificates, awards)
        VALUES
            (#{personalId}, #{certificates}, #{awards})
    </insert>

    <delete id="deleteByPersonalId" parameterType="java.lang.Long">
        DELETE FROM honors WHERE personal_id = #{personalId}
    </delete>

    <select id="selectByPersonalId" parameterType="java.lang.Long" resultType="multimodalinterviewaiback.pojo.entity.Honors">
        SELECT * FROM honors WHERE personal_id = #{personalId}
    </select>
</mapper>
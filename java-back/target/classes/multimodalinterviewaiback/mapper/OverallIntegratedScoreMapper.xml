<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="multimodalinterviewaiback.mapper.OverallIntegratedScoreMapper">
    <!-- 新增核心指标总结 -->
    <insert id="insert" parameterType="multimodalinterviewaiback.pojo.entity.OverallIntegratedScoreEntity" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO overallIntegratedScore (
            report_id,
            major,
            expression,
            logic,
            strain,
            stable
        ) VALUES (
                     #{report_id},
                     #{major},
                     #{expression},
                     #{logic},
                     #{strain},
                     #{stable}
                 )
    </insert>

    <!-- 根据报告ID查询核心指标 -->
    <select id="selectByReportId" parameterType="java.lang.Integer" resultType="multimodalinterviewaiback.pojo.entity.OverallIntegratedScoreEntity">
        SELECT
            id,
            report_id,
            major,
            expression,
            logic,
            strain,
            stable
        FROM overallIntegratedScore
        WHERE report_id = #{reportId}
    </select>

    <delete id="deleteByReportId" parameterType="java.lang.Integer">
        DELETE FROM overallIntegratedScore WHERE report_id = #{reportId}
    </delete>
</mapper>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="multimodalinterviewaiback.mapper.ProjectMapper">

    <insert id="batchInsert" parameterType="java.util.List">
        <!-- 当列表为空时，不执行插入操作 -->
        <if test="list != null and list.size() > 0">
            INSERT INTO project
            (personal_id, name, period, role, description, responsibilities, achievements)
            VALUES
            <foreach collection="list" item="item" separator=",">
                (#{item.personalId}, #{item.name}, #{item.period},
                #{item.role}, #{item.description}, #{item.responsibilities},
                #{item.achievements})
            </foreach>
        </if>
        <if test="list == null or list.size() == 0">
            <!-- 记录日志或者执行空操作 -->
            SELECT 1 FROM DUAL WHERE 1 = 0
        </if>
    </insert>

    <delete id="deleteByPersonalId" parameterType="java.lang.Long">
        DELETE FROM project WHERE personal_id = #{personalId}
    </delete>

    <select id="selectByPersonalId" parameterType="java.lang.Long" resultType="multimodalinterviewaiback.pojo.entity.Project">
        SELECT * FROM project WHERE personal_id = #{personalId}
    </select>
</mapper>